				</fusion_rates>
				</cell_interactions>
				<cell_transformations>
					<transformation_rates>
						<transformation_rate name="green" units="1/min">0</transformation_rate>
					</transformation_rates>
				</cell_transformations>


				<intracellular type="maboss">
